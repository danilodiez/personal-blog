---
export const prerender = true;
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const posts = await getCollection('posts');
const post = posts.find((p) => p.slug === slug);

if (!post) return Astro.redirect('/blog');

const { Content } = await post.render();
const date = post.data.date.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
---
<SiteLayout
  page="escritura"
  title={`${post.data.title} — Danilo Diez`}
  description={post.data.excerpt}
  ogType="article"
>

  <article class="article">
    <header class="article-header">
      <div class="article-meta">
        <span class="article-category">{post.data.category}</span>
        <span class="article-date">{date}</span>
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-excerpt">{post.data.excerpt}</p>
    </header>

    <div class="article-body">
      <Content />
    </div>

    <div class="article-footer">
      <button class="back-link" onclick="history.back()">← Volver</button>
    </div>
  </article>

</SiteLayout>

<style>
  .article {
    width: 100%;
  }

  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .article-category {
    font-family: var(--font);
    font-size: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-text);
  }

  .article-date {
    font-family: var(--font);
    font-size: 15px;
    color: var(--muted);
  }

  .article-title {
    font-family: var(--font);
    font-size: 48px;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .article-excerpt {
    font-family: var(--font);
    font-size: 22px;
    font-style: italic;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.6;
  }

  /* Prose styles for markdown content */
  .article-body :global(h2) {
    font-family: var(--font);
    font-size: 30px;
    font-weight: 400;
    color: var(--text);
    margin: 2.5rem 0 1rem;
    line-height: 1.3;
  }

  .article-body :global(h3) {
    font-family: var(--font);
    font-size: 22px;
    font-weight: 400;
    color: var(--text);
    margin: 2rem 0 0.75rem;
  }

  .article-body :global(p) {
    font-family: var(--font);
    font-size: 21px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 1.4rem;
  }

  .article-body :global(a) {
    color: var(--accent-text);
    text-decoration: underline;
    text-decoration-color: var(--accent-muted);
    text-underline-offset: 3px;
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .article-body :global(a:hover) {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    font-family: var(--font);
    font-size: 21px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 1.4rem;
    padding-left: 1.5rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--accent-muted);
    padding-left: 1.25rem;
    margin: 1.75rem 0;
    color: var(--muted);
    font-style: italic;
  }

  .article-body :global(code) {
    font-size: 0.875em;
    background: var(--hover-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15em 0.4em;
  }

  .article-body :global(pre) {
    background: var(--hover-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.4rem;
  }

  .article-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 16px;
    line-height: 1.6;
  }

  .article-body :global(img) {
    width: 100%;
    border-radius: 6px;
    border: 1px solid var(--border);
    margin: 1.5rem 0;
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .article-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    font-family: var(--font);
    font-size: 18px;
    color: var(--muted);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--accent-text); }

  @media (max-width: 640px) {
    .article-title { font-size: 34px; }
    .article-excerpt { font-size: 19px; }
  }
</style>
