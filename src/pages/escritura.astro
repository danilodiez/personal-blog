---
import SiteLayout from '../layouts/SiteLayout.astro';
import BlogsPreview from '../components/BlogsPreview.astro';
import { getLocaleCollection } from '../i18n/utils';

function decodeEntities(str: string) {
  return str
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#(\d+);/g, (_, n) => String.fromCharCode(Number(n)))
    .replace(/&#x([0-9a-f]+);/gi, (_, h) => String.fromCharCode(parseInt(h, 16)));
}

function parseRss(xml: string) {
  const items = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)];
  return items
    .slice(0, 10)
    .map(([, item]) => {
      const title = decodeEntities((
        item.match(/<title><!\[CDATA\[(.*?)\]\]><\/title>/)?.[1] ??
        item.match(/<title>(.*?)<\/title>/)?.[1] ??
        ''
      ).trim());
      const url = (
        item.match(/<link>(.*?)<\/link>/)?.[1] ??
        item.match(/<guid[^>]*>(.*?)<\/guid>/)?.[1] ??
        'https://danilodiez.substack.com'
      ).trim();
      const pubDate = item.match(/<pubDate>(.*?)<\/pubDate>/)?.[1] ?? '';
      const desc = (
        item.match(/<description><!\[CDATA\[([\s\S]*?)\]\]><\/description>/)?.[1] ??
        item.match(/<description>([\s\S]*?)<\/description>/)?.[1] ??
        ''
      );
      const plain = decodeEntities(desc.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim());
      const excerpt = plain.length > 160 ? plain.slice(0, 160) + '…' : plain;
      const date = pubDate
        ? new Date(pubDate).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' })
        : '';
      return { title, url, date, excerpt, category: 'Substack' };
    })
    .filter(p => p.title.length > 0);
}

let substackPosts: { title: string; url: string; date: string; excerpt: string; category: string }[] = [];
try {
  const res = await fetch('https://danilodiez.substack.com/feed', { signal: AbortSignal.timeout(6000) });
  if (res.ok) substackPosts = parseRss(await res.text());
} catch (_) {}

const localPosts = (await getLocaleCollection('posts', 'es'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map(p => ({
    title: p.data.title,
    date: p.data.date.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' }),
    excerpt: p.data.excerpt,
    url: p.data.url ?? `#`,
    category: p.data.category,
  }));

const posts = [...localPosts, ...substackPosts];

---
<SiteLayout page="escritura" title="Escritura — Danilo Diez">

  <div class="section-header">
    <p class="section-eyebrow">Escritura</p>
    <h1 class="section-title">Palabras, despacio.</h1>
    <p class="section-lead">Ensayos, críticas, pensamientos a medio formar. Algunos en Substack, otros solo acá.</p>
  </div>

  <BlogsPreview posts={posts} />

</SiteLayout>
